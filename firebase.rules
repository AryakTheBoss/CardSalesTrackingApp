rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow users who are logged in to read and write to the database
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid != 'pPkHtsuRKnV2Fobnh20M9WsXDRz1';
    }
  }
}
